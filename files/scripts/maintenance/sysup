#!/bin/bash
# shellcheck disable=SC1091,SC2059
# 描述： 更新系统根
# Description: Update system

# 开启严格模式：遇到错误、未定义变量、管道错误即停止运行
set -euo pipefail

SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || printf '%s\n' "$0")"
SCRIPT_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd -P)"

# ===============================================================
# Arch Linux 系统更新助手 (KISS 终极联动版 - 防部分升级 + 强制刷新)
# ===============================================================

# ------------------------------
# 1. Default parameters & KISS Language Detection
# ------------------------------
COUNT_LIMIT=15
NEWS_SOURCE="official"
SHOW_LIST=0

if [[ "${LC_MESSAGES:-${LANG:-}}" == *zh_CN* ]]; then
  UI_LANG="zh"
else
  UI_LANG="en"
fi

# ------------------------------
# 2. Define Colors
# ------------------------------
NC='\033[0m'
H_RED='\033[1;31m'
H_GREEN='\033[1;32m'
H_YELLOW='\033[1;33m'
H_BLUE='\033[1;34m'
H_CYAN='\033[1;36m'

# ------------------------------
# 3. Argument parsing
# ------------------------------
usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

Options:
  -l, --list               Launch list (checkallupdates) before updates
  --ui-lang zh|en          UI language (default: auto)
  --news-source official|cn  News source (default: official)
  --count N                Max number of news items (default: 15)
  --help, -h               Show this help and exit
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
  -l | --list) SHOW_LIST=1; shift 1 ;;
  --ui-lang) [[ -n "${2:-}" ]] && UI_LANG="$2" && shift 2 || exit 1 ;;
  --news-source) [[ -n "${2:-}" ]] && NEWS_SOURCE="$2" && shift 2 || exit 1 ;;
  --count) [[ -n "${2:-}" ]] && COUNT_LIMIT="$2" && shift 2 || exit 1 ;;
  --help | -h)
    usage
    exit 0
    ;;
  *)
    printf "Unknown option: %s\n" "$1"
    usage
    exit 1
    ;;
  esac
done

# ------------------------------
# 4. Localization Logic
# ------------------------------
declare -A MSG
if [[ "$UI_LANG" == "zh" ]]; then
