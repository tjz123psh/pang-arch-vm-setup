fzf_colors() {
  printf '%s' 'fg:#cdd6f4,bg:-1,hl:#f9e2af,fg+:#11111b,bg+:#f9e2af,hl+:#11111b,prompt:#89b4fa,pointer:#f38ba8,marker:#a6e3a1,border:#f9e2af,header:#bac2de,label:#f9e2af,preview-fg:#cdd6f4'
}

choose_menu() {
  local title="$1"
  local items="$2"
  local selected choice key label act desc status

  if command -v fzf >/dev/null 2>&1; then
    set +e
    selected="$(
      printf "%s\n" "$items" |
        fzf \
          --delimiter=$'\t' \
          --with-nth=1,2 \
          --height=96% \
          --min-height=24 \
          --layout=reverse \
          --border=rounded \
          --border-label=" $title " \
          --prompt='选择 > ' \
          --pointer='▶' \
          --marker='✓' \
          --info=hidden \
          --no-separator \
          --header='Enter 执行 · Esc 返回/退出' \
          --preview-window='down,12,border-top,wrap' \
          --preview="bash '$SELF' --preview {3}" \
          --color="$(fzf_colors)"
    )"
    status=$?
    set -e
    [ "$status" -eq 0 ] || return 1
  else
    printf "${CYAN}%s${NC}\n" "$title"
    printf "${DIM}────────────────────────────────────────${NC}\n"
    while IFS=$'\t' read -r key label act desc; do
      [ -n "$key" ] || continue
      if [ "$act" = "__exit" ]; then
        printf "  ${CYAN}%s${NC}  %-12s ${DIM}%s${NC}\n" "$key" "$label" "$desc"
      else
        printf "  ${CYAN}%s${NC}  %-12s ${DIM}%-18s${NC} %s\n" "$key" "$label" "$act" "$desc"
      fi
    done <<< "$items"
    printf "${DIM}────────────────────────────────────────${NC}\n"
    read -rp "选择操作: " choice
    selected="$(printf "%s\n" "$items" | awk -F '\t' -v key="$choice" '$1 == key || $1 + 0 == key {print; exit}')"
    [ -n "$selected" ] || return 1
  fi

  printf '%s\n' "$selected"
}

run_command() {
  local act="$1"

  if command -v "$act" >/dev/null 2>&1; then
    if [ "$act" = "migration-pack" ]; then
      if TERM_MENU_CHILD=1 "$act"; then
        return 0
      else
        return $?
      fi
    elif "$act"; then
      return 0
    else
      return $?
    fi
  else
    printf "${RED}命令不可用:${NC} %s\n" "$act"
  fi
}

exit_menu() {
  if command -v niri >/dev/null 2>&1; then
    if niri msg -j focused-window 2>/dev/null | grep -q '"app_id":"term-menu"'; then
      niri msg action close-window >/dev/null 2>&1 || true
    fi
  fi

  exit 0
}

