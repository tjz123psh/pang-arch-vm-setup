show_snapshots() {
  local conf cols desc_width tmp line_count page_lines

  if ! command -v snapper >/dev/null 2>&1; then
    printf "${RED}缺少依赖:${NC} snapper\n"
    return 1
  fi

  cols="$(tput cols 2>/dev/null || true)"
  if [[ ! "$cols" =~ ^[0-9]+$ ]]; then
    cols=80
  fi

  desc_width=$((cols - 58))
  if [ "$desc_width" -lt 16 ]; then
    desc_width=16
  elif [ "$desc_width" -gt 38 ]; then
    desc_width=38
  fi

  draw_line() {
    local count="$1"
    printf '─%.0s' $(seq 1 "$count")
  }

  compact_text() {
    local text="$1"
    local max="$2"

    if [ "${#text}" -gt "$max" ]; then
      printf '%s...' "${text:0:max-3}"
    else
      printf '%s' "$text"
    fi
  }

  print_snapshot_list() {
    local conf="$1"
    local rows number date user cleanup desc
    local date_display desc_display
    local sep=$'\037'
    local count=0 entries="" status status_color line_width

    line_width=$((cols - 8))
    if [ "$line_width" -lt 58 ]; then
      line_width=58
    elif [ "$line_width" -gt 88 ]; then
      line_width=88
    fi

    if ! rows="$(snapper --csvout --separator "$sep" --iso -c "$conf" list --columns number,date,user,cleanup,description 2>/dev/null)"; then
      printf "\n${CYAN}${BOLD}╭─ %s 快照${NC}\n" "$conf"
      printf "${DIM}│${NC} ${YELLOW}配置不存在或无法读取:${NC} %s\n" "$conf"
      printf "${CYAN}╰"; draw_line "$line_width"; printf "${NC}\n"
      return 0
    fi

    while IFS="$sep" read -r number date user cleanup desc; do
      [ "$number" = "number" ] && continue
      [ -n "$number" ] || continue

      if [ -n "$date" ]; then
        date_display="${date%:*}"
        status="快照"
        status_color="$CYAN"
      else
        date_display="当前"
        status="当前"
        status_color="$GREEN"
      fi

      [ -n "$user" ] || user="-"
      [ -n "$cleanup" ] || cleanup="-"
      [ -n "$desc" ] || desc="-"
      desc_display="$(compact_text "$desc" "$desc_width")"
      count=$((count + 1))

      entries+=$(printf "${DIM}│${NC} %b%-4s%b  ${YELLOW}#%-4s${NC} %-16s  %-8s %-8s %s" \
        "$status_color" "$status" "$NC" "$number" "$date_display" "$user" "$cleanup" "$desc_display")
      entries+=$'\n'
    done <<< "$rows"

    printf "\n${CYAN}${BOLD}╭─ %s 快照${NC} ${DIM}%s 个条目${NC}\n" "$conf" "$count"
    printf "${DIM}│${NC} %-4s  %-5s %-16s  %-8s %-8s %s\n" "状态" "ID" "时间" "用户" "清理" "描述"
    printf "${CYAN}├"; draw_line "$line_width"; printf "${NC}\n"
    if [ -n "$entries" ]; then
      printf "%s" "$entries"
    else
      printf "${DIM}│${NC} ${YELLOW}没有快照记录${NC}\n"
    fi
    printf "${CYAN}╰"; draw_line "$line_width"; printf "${NC}\n"
  }

  tmp="$(mktemp)"
  {
    for conf in root home; do
      print_snapshot_list "$conf"
    done

    printf "\n${DIM}这里只查看快照；恢复用 quickload，删除用\"删除快照\"。${NC}\n"
  } > "$tmp"

  line_count="$(wc -l < "$tmp")"
  page_lines="$(tput lines 2>/dev/null || true)"
  if [[ ! "$page_lines" =~ ^[0-9]+$ ]]; then
    page_lines=24
  fi
  page_lines=$((page_lines - 4))

  if [ -t 1 ] && [ "$line_count" -gt "$page_lines" ]; then
    if command -v less >/dev/null 2>&1; then
      LESS=FRX less -R "$tmp"
    elif command -v more >/dev/null 2>&1; then
      more "$tmp"
    else
      cat "$tmp"
    fi
  else
    cat "$tmp"
  fi

  rm -f "$tmp"
}

delete_snapshot() {
  if ! command -v snapper >/dev/null 2>&1 || ! command -v quicksave >/dev/null 2>&1; then
    printf "${RED}缺少依赖:${NC} snapper 或 quicksave\n"
    return 1
  fi

  local conf snapshots selected snap_ids=() snap_id snap_date snap_desc confirm
  local sep=$'\037'
  local config_rows config_name subvolume config_items index
  local snap_rows number date desc

  config_rows="$(snapper --csvout --separator "$sep" list-configs 2>/dev/null || true)"
  config_items=""
  index=1

  while IFS="$sep" read -r config_name subvolume; do
    [ "$config_name" = "config" ] && continue
    [ -n "$config_name" ] || continue

    config_items+=$(printf "%02d\t%s\t%s\t删除 %s 下的快照" "$index" "$config_name" "$config_name" "${subvolume:-该配置}")
    config_items+=$'\n'
    index=$((index + 1))
  done <<< "$config_rows"

  if [ -z "$config_items" ]; then
    printf "${RED}未找到 Snapper 配置${NC}\n"
    return 1
  fi

  conf="$(choose_menu "选择快照配置" "$config_items")" || return 0
  IFS=$'\t' read -r _ _ conf _ <<< "$conf"
  [ -z "$conf" ] && return 0

  snap_rows="$(snapper --csvout --separator "$sep" --iso -c "$conf" list --columns number,date,description 2>/dev/null || true)"
  snapshots=""

  while IFS="$sep" read -r number date desc; do
    [ "$number" = "number" ] && continue
    [[ "$number" =~ ^[0-9]+$ ]] || continue
    [ "$number" != "0" ] || continue

    if [ -n "$date" ]; then
      date="${date%:*}"
    else
      date="当前"
    fi

    [ -n "$desc" ] || desc="(无描述)"
    desc="${desc//$'\t'/ }"
    snapshots+=$(printf "%s\t%s\t%s" "$number" "$date" "$desc")
    snapshots+=$'\n'
  done <<< "$snap_rows"

  if [ -z "$snapshots" ]; then
    printf "${YELLOW}配置 [%s] 没有可删除快照${NC}\n" "$conf"
    return 0
  fi

  if command -v fzf >/dev/null 2>&1; then
    selected=$(
      printf "%s\n" "$snapshots" |
        fzf \
          --delimiter=$'\t' \
          --with-nth=1,2,3 \
          --multi \
          --height=82% \
          --layout=reverse \
          --border=rounded \
          --border-label=" 删除快照 [$conf] " \
          --prompt='快照 > ' \
          --header='Tab 多选 · Shift+Tab 取消 · Enter 确认 · Esc 取消' \
          --preview='printf "\033[36mID\033[0m    {1}\n\033[36m时间\033[0m  {2}\n\033[36m描述\033[0m  {3}\n"' \
          --preview-window='down,5,border-top' \
          --info=hidden \
          --no-separator \
          --color="$(fzf_colors)"
    ) || return 0
  else
    printf "%s\n" "$snapshots"
    printf "\n输入要删除的快照 ID，多个用空格分隔: "
    read -r snap_id
    selected="$snap_id"
  fi

  [ -z "$selected" ] && return 0

  printf "${YELLOW}准备删除:${NC} 配置 [%s]\n" "$conf"
  while IFS= read -r line; do
    if [[ "$line" == *$'\t'* ]]; then
      IFS=$'\t' read -r snap_id snap_date snap_desc <<< "$line"
    else
      snap_id="$line"
      snap_date=""
      snap_desc=""
    fi

    if [[ ! "$snap_id" =~ ^[0-9]+$ ]]; then
      printf "${RED}无效快照 ID:${NC} %s\n" "$snap_id"
      return 1
    fi

    snap_ids+=("$snap_id")
    printf "  #%s" "$snap_id"
    [ -n "${snap_date:-}" ] && printf "  %s" "$snap_date"
    [ -n "${snap_desc:-}" ] && printf "  %s" "$snap_desc"
    printf "\n"
  done <<< "$selected"

  printf "\n输入 ${RED}delete${NC} 确认删除: "
  read -r confirm
  if [ "$confirm" != "delete" ]; then
    printf "已取消。\n"
    return 0
  fi

  for snap_id in "${snap_ids[@]}"; do
    quicksave -c "$conf" -del "$snap_id"
  done
}

