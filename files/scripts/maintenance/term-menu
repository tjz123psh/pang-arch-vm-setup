ui_rule() {
  local count="$1"
  local i

  for ((i = 0; i < count; i++)); do
    printf '─'
  done
}

pause_for_menu() {
  local cols width

  cols="$(tput cols 2>/dev/null || true)"
  if [[ ! "$cols" =~ ^[0-9]+$ ]]; then
    cols=80
  fi

  width=$((cols - 8))
  if [ "$width" -lt 36 ]; then
    width=36
  elif [ "$width" -gt 88 ]; then
    width=88
  fi

  printf "\n${CYAN}╭─ 返回维护菜单${NC}\n"
  printf "${DIM}│${NC} 任意键返回\n"
  printf "${CYAN}╰"
  ui_rule "$width"
  printf "${NC}"

  if [ -t 1 ]; then
    tput civis 2>/dev/null || true
  fi
  IFS= read -r -s -n 1 || true
  show_cursor
}

run_action() {
  local label="$1"
  local act="$2"

  if [ "$act" = "__exit" ]; then
    exit_menu
  fi

  clear
  printf "${CYAN}==>${NC} %s ${DIM}(%s)${NC}\n\n" "$label" "$act"

  case "$act" in
    __update_menu) show_update_menu ;;
    __clean_menu) show_clean_menu ;;
    __snapshot_menu) show_snapshot_menu ;;
    __check_menu) show_check_menu ;;
    __network_menu) show_network_menu ;;
    clean-all) run_clean_all ;;
    cache-clean-safe) run_cache_clean_safe ;;
    cache-clean-dev) run_cache_clean_dev ;;
    cache-clean-chrome) run_cache_clean_chrome ;;
    delete-snapshot) delete_snapshot ;;
    view-snapshots) show_snapshots ;;
    network-status) show_network_status ;;
    blueman-manager|blueberry)
      "$act" &
      printf "${GREEN}已启动:${NC} %s\n" "$label"
      sleep 1
      ;;
    *)
      run_command "$act"
      ;;
  esac
}

show_main_menu() {
  local selected key label act desc
  selected="$(choose_menu "维护菜单" "$MAIN_ITEMS")" || exit_menu
  IFS=$'\t' read -r key label act desc <<< "$selected"
  run_action "$label" "$act"
}

while true; do
  clear
  if show_main_menu; then
    status=0
  else
    status=$?
  fi
  if [ "$status" -eq 10 ]; then
    continue
  fi
  pause_for_menu
  clear
done
