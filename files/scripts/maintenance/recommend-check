#!/usr/bin/env bash
set -euo pipefail

NC=$'\033[0m'
RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
CYAN=$'\033[36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'

if [[ ! -t 1 ]]; then
  NC=""; RED=""; GREEN=""; YELLOW=""; CYAN=""; BOLD=""; DIM=""
fi

ok() { printf '%sOK%s    %s\n' "$GREEN" "$NC" "$*"; }
warn() { printf '%sWARN%s  %s\n' "$YELLOW" "$NC" "$*"; }
miss() { printf '%sMISS%s  %s\n' "$RED" "$NC" "$*"; }
info() { printf '%sINFO%s  %s\n' "$CYAN" "$NC" "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }

declare -A INSTALLED_PKGS=()

load_installed_pkgs() {
  local pkg

  while IFS= read -r pkg; do
    [[ -n "$pkg" ]] && INSTALLED_PKGS["$pkg"]=1
  done < <(pacman -Qq 2>/dev/null || true)
}

pkg_installed() { [[ -n "${INSTALLED_PKGS[$1]:-}" ]]; }

section() {
  printf '\n%s== %s ==%s\n' "$BOLD" "$1" "$NC"
}

is_vm() {
  have systemd-detect-virt && systemd-detect-virt --quiet 2>/dev/null
}

first_gpu_line() {
  if have lspci; then
    LC_ALL=C lspci | awk '/VGA|3D|Display/ {print; exit}'
  fi
}

cpu_vendor() {
  if have lscpu; then
    LC_ALL=C lscpu | awk -F: '/Vendor ID/ {gsub(/^[ \t]+/, "", $2); print $2; exit}'
  fi
}

has_bluetooth_controller() {
  [[ -d /sys/class/bluetooth ]] && find /sys/class/bluetooth -mindepth 1 -maxdepth 1 2>/dev/null | grep -q .
}

unique_join() {
  if [ "$#" -eq 0 ]; then
    return 0
  fi
  printf '%s\n' "$@" | awk 'NF && !seen[$0]++' | paste -sd' ' -
}

install_pkgs=()
conditional_pkgs=()
optional_pkgs=()

record_missing() {
  local pkg="$1"
  local level="$2"

  case "$level" in
    必要|推荐) install_pkgs+=("$pkg") ;;
    条件) conditional_pkgs+=("$pkg") ;;
    可选) optional_pkgs+=("$pkg") ;;
  esac
}

check_item() {
  local pkg="$1"
  local cmd="$2"
  local level="$3"
  local label="$4"
  local reason="$5"
  local prefix

  prefix="[$level] $pkg - $label"

  if pkg_installed "$pkg"; then
    ok "$prefix"
    printf "      %s%s%s\n" "$DIM" "$reason" "$NC"
    return 0
  fi

  if [[ -n "$cmd" ]] && have "$cmd"; then
    warn "$prefix 未显式安装，但命令已可用: $cmd"
    printf "      %s%s%s\n" "$DIM" "$reason" "$NC"
    return 0
  fi

  case "$level" in
    必要) miss "$prefix" ;;
    推荐|条件) warn "$prefix" ;;
    可选) info "$prefix" ;;
    *) warn "$prefix" ;;
  esac
  printf "      %s%s%s\n" "$DIM" "$reason" "$NC"
  record_missing "$pkg" "$level"
}

check_group() {
  local title="$1"
  shift
  local item pkg cmd level label reason

  section "$title"
  for item in "$@"; do
    IFS='|' read -r pkg cmd level label reason <<< "$item"
    check_item "$pkg" "$cmd" "$level" "$label" "$reason"
  done
}

main() {
  local vendor gpu virt microcode_pkg microcode_reason
  local core_items hardware_items desktop_items
  local install_line conditional_line optional_line

  if ! have pacman; then
    miss "缺少 pacman；这不是可识别的 Arch 环境"
    exit 1
  fi
  load_installed_pkgs

  vendor="$(cpu_vendor || true)"
  gpu="$(first_gpu_line || true)"
  if is_vm; then
    virt="$(systemd-detect-virt 2>/dev/null || printf 'virtual')"
  else
    virt="physical"
  fi

  section "当前环境"
  info "运行环境: $virt"
  info "CPU 厂商: ${vendor:-unknown}"
  info "GPU: ${gpu:-unknown}"
  if has_bluetooth_controller; then
    info "蓝牙控制器: detected"
  else
    info "蓝牙控制器: 未检测到或当前环境未暴露"
  fi

  core_items=(
    "efibootmgr|efibootmgr|必要|UEFI 启动项检查|双系统实机上用来确认 Windows Boot Manager 和 Arch/GRUB 启动项是否还在。"
    "os-prober|os-prober|必要|GRUB 探测 Windows|生成 grub.cfg 前确认 Windows 是否能被发现，避免装完 Arch 后菜单没有 Windows。"
    "shellcheck|shellcheck|推荐|维护脚本静态检查|改 term-menu、sysup、clean 等脚本前先跑，能提前发现常见 Bash 问题。"
    "downgrade|downgrade|可选|pacd 降级工具|pacd 强依赖 downgrade；不需要包版本回退时可以不装。"
    "strace|strace|可选|pacrrr 残留追踪|pacrrr 需要用 strace 追踪应用读写路径；不用残留追踪清理时可以不装。"
    "upower|upower|可选|check-battery 电池读取|check-battery 通过 upower 读取电池状态；台式机或不用该脚本时可以不装。"
  )

  hardware_items=(
    "smartmontools|smartctl|推荐|SSD SMART 健康检查|实机迁移和长期使用时查看 NVMe/SATA 健康、通电时间和错误计数。"
    "fwupd|fwupdmgr|推荐|固件更新检查|支持的机器可以查看 BIOS、SSD、扩展坞等固件更新；不会自动更新。"
    "vulkan-tools|vulkaninfo|推荐|Vulkan / GPU 诊断|gpu-check 需要它输出 Vulkan 摘要，游戏和硬件加速排障也常用。"
    "btop|btop|推荐|终端资源监控|比 top 更直观，适合看 CPU、内存、磁盘和进程占用。"
    "powertop|powertop|推荐|功耗诊断|笔记本实机上看耗电来源和省电建议；台式机可选。"
  )

  desktop_items=(
    "mpv|mpv|推荐|b23 显式播放器依赖|当前可能由 celluloid 间接带入，实机迁移建议显式安装，避免 b23 断依赖。"
    "sof-firmware||条件|新机器音频固件|如果实机扬声器、麦克风、声卡异常，优先补它；虚拟机里不一定需要。"
    "flatpak|flatpak|可选|Flatpak 应用支持|如果继续使用 Flatpak 应用或运行时，再安装；不使用可以不装。"
  )

  if has_bluetooth_controller; then
    desktop_items+=("blueman|blueman-manager|可选|蓝牙图形管理|有蓝牙键鼠或耳机时更方便；term-menu 会自动发现 blueman-manager。")
  else
    desktop_items+=("blueman|blueman-manager|可选|蓝牙图形管理|当前没检测到蓝牙控制器，实机有蓝牙外设时再考虑。")
  fi

  if [[ "$virt" != "physical" ]]; then
    info "当前是虚拟机，CPU 微码包按实机 CPU 再决定，不在这里强推。"
  else
    case "$vendor" in
      *AuthenticAMD*|*AMD*)
        microcode_pkg="amd-ucode"
        microcode_reason="AMD 实机建议安装，并在 grub-mkconfig 后进入 GRUB 启动链。"
        ;;
      *GenuineIntel*|*Intel*)
        microcode_pkg="intel-ucode"
        microcode_reason="Intel 实机建议安装，并在 grub-mkconfig 后进入 GRUB 启动链。"
        ;;
      *)
        microcode_pkg=""
        microcode_reason=""
        ;;
    esac
    if [[ -n "${microcode_pkg:-}" ]]; then
      hardware_items+=("$microcode_pkg||必要|CPU 微码|$microcode_reason")
    fi
  fi

  check_group "双系统 / 脚本维护" "${core_items[@]}"
  check_group "硬件 / 性能 / 固件" "${hardware_items[@]}"
  check_group "桌面体验 / 条件可选" "${desktop_items[@]}"

  section "AUR 审查 / AI 可选项"
  if have opencode; then
    ok "[可选] opencode-bin - paru-ui AUR 审查"
    printf "      %s%s%s\n" "$DIM" "paru-ui -c 和 AUR 安装前审查会调用 opencode；官方仓库包不走这套提示词。" "$NC"
  else
    info "[可选] opencode-bin - paru-ui AUR 审查"
    printf "      %s%s%s\n" "$DIM" "需要 AUR 审查时安装：paru -S --needed opencode-bin" "$NC"
  fi

  if [[ -f "$HOME/scripts/share/prompts/aur-review.md" ]]; then
    ok "[必要] aur-review.md - paru-ui AUR 审查提示词"
    printf "      %s%s%s\n" "$DIM" "提示词存在于 ~/scripts/share/prompts/aur-review.md。" "$NC"
  else
    warn "[必要] aur-review.md - paru-ui AUR 审查提示词缺失"
    printf "      %s%s%s\n" "$DIM" "缺失时 paru-ui -c 不能执行 AUR 审查，普通安装模式会提示并退回常规 AUR 流程。" "$NC"
  fi

  section "建议安装命令"
  install_line="$(unique_join "${install_pkgs[@]}")"
  conditional_line="$(unique_join "${conditional_pkgs[@]}")"
  optional_line="$(unique_join "${optional_pkgs[@]}")"

  if [[ -n "$install_line" ]]; then
    printf '%s\n' "sudo pacman -S --needed $install_line"
  else
    ok "必要/推荐项已补齐"
  fi

  if [[ -n "$conditional_line" ]]; then
    printf '\n%s条件项按问题安装:%s\n' "$YELLOW" "$NC"
    printf '%s\n' "sudo pacman -S --needed $conditional_line"
  fi

  if [[ -n "$optional_line" ]]; then
    printf '\n%s可选项按需安装:%s\n' "$CYAN" "$NC"
    printf '%s\n' "sudo pacman -S --needed $optional_line"
  fi

  printf '\n%s说明:%s recommend-check 只读检查，不会安装软件，也不会修改系统配置。\n' "$CYAN" "$NC"
}

main "$@"
