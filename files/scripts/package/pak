#!/usr/bin/env bash
# 描述： Flatpak安装软件TUI
# Description: Flatpak pkgs installation TUI
# Features:
#   1. 模糊搜索并批量安装 Flatpak 软件包
#   2. 自动检测系统并准确标记 [已安装] 的软件包
#   3. 后台异步加载原生缓存数据，界面秒开不阻塞
#   4. 清爽排版：来源仓库 | 应用名称 | App ID | 状态标记
#   5. 巧妙利用 awk $NF 提取 ID，无需破坏视觉的定界符
#   6. 实时下半屏预览软件包详细信息
#   7. 启动时前置检查 Remote 配置，避免空跑
#   8. 具备优雅降级机制：本地缓存失效或为空时，自动回退到实时网络拉取
#   9. 强健的 AWK 解析：修复了纯净系统下已安装列表为空导致的吞噬陷阱
# ==============================================================================
# 启用严格的错误处理机制
set -euo pipefail

SHELL="$(grep -m 1 -E '^/.*/bash$' /etc/shells || echo /bin/bash)"
export SHELL

# --- 1. 环境与基础配置 ---
ORIGINAL_LANG="${LC_ALL:-${LC_MESSAGES:-${LANG:-C}}}"
export ORIGINAL_LANG
SHOW_HELP=false
FORCE_REFRESH=false
QUERY_ARGS=()

export LC_ALL=C

# --- 2. 参数解析 ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)
            SHOW_HELP=true
            shift
            ;;
        --refresh|-y)
            FORCE_REFRESH=true
            shift
            ;;
        *)
            QUERY_ARGS+=("$1")
            shift
            ;;
    esac
done

# --- 3. 本地化多语言字典 ---
declare -A MSG
if [[ "$ORIGINAL_LANG" == *"zh_CN"* ]]; then
    MSG[DESC]="模糊搜索并安装 Flatpak 软件包。"
    MSG[OPTS]="选项："
    MSG[OPT_HELP]="  --help, -h    显示此帮助信息并退出"
    MSG[OPT_REFRESH]="  --refresh, -y 强制更新 Flatpak AppStream缓存"
    MSG[FEAT]="功能特性："
    MSG[FEAT_1]="- 准确状态：自动比对并显示 [已安装] 标记"
    MSG[FEAT_2]="- 无界排版：清爽的空格对齐，拒绝多余符号"
    MSG[FEAT_3]="- 原生调用：遵循 KISS 原则"
    MSG[EX]="示例："
    MSG[ERR_FZF]="错误：未找到 fzf，请先安装。"
    MSG[ERR_HELPER]="错误：未找到 flatpak，请确认已在系统中安装并配置。"
    MSG[ERR_REMOTE]="错误：当前系统未配置任何 Flatpak 软件源 (Remotes)。"
    MSG[FIX_REMOTE]="修复命令：flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo"
    MSG[INSTALLED]="[已安装]"
    MSG[INSTALLING]=">> 准备安装："
    MSG[REFRESHING]=">> 正在刷新 Flatpak 缓存..."
    MSG[HEADER]="Tab:多选 | Enter:安装 | Esc:退出"
    MSG[EXEC]="> 正在执行: "
    MSG[HINT]="如需重试或记录，可复制以下命令："
else
    MSG[DESC]="Fuzzy search & install Flatpak packages."
    MSG[OPTS]="Options:"
    MSG[OPT_HELP]="  --help, -h    Show this help and exit"
    MSG[OPT_REFRESH]="  --refresh, -y Force update Flatpak AppStream cache"
    MSG[FEAT]="Features:"
    MSG[FEAT_1]="- Accurate status: [Installed] tag"
    MSG[FEAT_2]="- Clean UI: Space-aligned, no messy delimiters"
    MSG[FEAT_3]="- Native: KISS principle"
    MSG[EX]="Example:"
    MSG[ERR_FZF]="Error: fzf not found."
    MSG[ERR_HELPER]="Error: flatpak not found."
    MSG[ERR_REMOTE]="Error: No Flatpak remotes configured."
    MSG[FIX_REMOTE]="Fix: flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo"
    MSG[INSTALLED]="[Installed]"
    MSG[INSTALLING]=">> Installing:"
    MSG[REFRESHING]=">> Refreshing Flatpak cache..."
    MSG[HEADER]="Tab:Multi-Select | Enter:Install | Esc:Exit"
    MSG[EXEC]="> Executing: "
    MSG[HINT]="For retry or logging, copy the command below:"
fi

# --- 4. 帮助信息拦截 ---
if [ "$SHOW_HELP" = true ]; then
    cat <<EOF
Usage: ${0##*/} [options] [query]

${MSG[OPTS]}
${MSG[OPT_HELP]}
${MSG[OPT_REFRESH]}

Description:
  ${MSG[DESC]}

${MSG[FEAT]}
  ${MSG[FEAT_1]}
  ${MSG[FEAT_2]}
  ${MSG[FEAT_3]}

${MSG[EX]}
  ${0##*/} obs          # 搜索 'obs'
  ${0##*/} -y           # 强制刷新缓存并列出所有包
EOF
    exit 0
fi

# --- 5. 核心依赖检查 ---
command -v fzf >/dev/null 2>&1 || { echo "${MSG[ERR_FZF]}" >&2; exit 1; }
command -v flatpak >/dev/null 2>&1 || { echo "${MSG[ERR_HELPER]}" >&2; exit 1; }

# 检查是否存在至少一个 Remote 源
if [[ -z "$(flatpak remotes --columns=name 2>/dev/null)" ]]; then
    echo -e "\033[31m${MSG[ERR_REMOTE]}\033[0m" >&2
    echo "${MSG[FIX_REMOTE]}" >&2
    exit 1
fi

# --- 6. 异步逻辑与文件安全设置 ---
TMP_DIR=$(mktemp -d /tmp/flatpak_fzf.XXXXXX)
TARGET_FILE="${TMP_DIR}/target"
INSTALLED_LIST="${TMP_DIR}/installed"
PIPE_FIFO="${TMP_DIR}/fifo"
mkfifo "$PIPE_FIFO"

cleanup() {
    if [[ -n "${PID_GEN:-}" ]]; then kill "$PID_GEN" 2>/dev/null || true; fi
    rm -rf "$TMP_DIR"
}
trap cleanup EXIT INT TERM

if [[ "$FORCE_REFRESH" == true ]]; then
    echo -e "\033[33m${MSG[REFRESHING]}\033[0m"
    flatpak update --appstream
fi

flatpak list --app --columns=application > "$INSTALLED_LIST" || true

# --- 7. 数据生成器 (后台运行) ---
# shellcheck disable=SC2016
AWK_CMD='
    # 修复经典陷阱：使用 FILENAME == ARGV[1] 替代 FNR==NR
    FILENAME == ARGV[1] { installed[$1]=1; next }
    {
        origin = $1
        app_id = $2
        
        $1=""; $2=""
        name=$0
        sub(/^[ \t]+/, "", name)
        
        status = (app_id in installed) ? ci " ✔ " label r : ""
        printf "%s%-10s%s %-38s %-35s%s\n", c, origin, r, name, app_id, status
    }
'

(
    # 核心防御 1：优先尝试秒开模式 (利用缓存)
    RAW_DATA=$(flatpak remote-ls --app --cached --columns=origin,application,name 2>/dev/null || true)
    
    # 核心防御 2：如果缓存为空（完美拦截虚拟机中的缓存失效问题），降级走实时拉取模式
    if [[ -z "$RAW_DATA" ]]; then
        RAW_DATA=$(flatpak remote-ls --app --columns=origin,application,name 2>/dev/null || true)
    fi

    # 渲染数据：无论走哪种模式，只要拿到数据就喂给 awk
    if [[ -n "$RAW_DATA" ]]; then
        echo "$RAW_DATA" | \
        awk -v c='\033[36m' -v ci='\033[32m' -v r='\033[0m' \
            -v label="${MSG[INSTALLED]}" \
            "$AWK_CMD" "$INSTALLED_LIST" - 2>/dev/null
    else
        # 极限情况：给 fzf 界面输出一个明显的错误提示
        printf "\033[31m%-10s %-38s %-35s\033[0m\n" "Error" "Failed to fetch Flatpak remotes." "Please check your network."
    fi
) > "$PIPE_FIFO" &

PID_GEN=$!

# --- 8. 交互式 FZF 渲染 ---
COLOR_CYAN=$'\033[36m'
COLOR_RESET=$'\033[0m'
FZF_HEADER="${MSG[HEADER]} | ${COLOR_CYAN}Using Flatpak${COLOR_RESET}"

# 【关键修复】: 
# 1. 注入 LC_ALL=$ORIGINAL_LANG 使得预览窗口也显示中文。
# 2. 因为 flatpak 没有原生色彩支持，通过 awk 手动为包含冒号(:或：) 的 Key 添加 Cyan (\033[36m) 色彩。
PREVIEW_CMD="line={}; clean=\$(echo \"\$line\" | sed 's/ ✔ .*//'); o=\$(echo \"\$clean\" | awk '{print \$1}'); a=\$(echo \"\$clean\" | awk '{print \$NF}'); LC_ALL=\$ORIGINAL_LANG flatpak remote-info --cached \"\$o\" \"\$a\" | awk '{ sub(/^[ \\t]*[^:：]*[:：]/, \"\\033[36m&\\033[0m\"); print }'"

set +e
fzf --multi --ansi \
    --preview "$PREVIEW_CMD" \
    --preview-window=down:55%:wrap \
    --height=95% --layout=reverse --border \
    --tiebreak=index \
    --bind "alt-j:last,alt-k:first" \
    --nth=2.. \
    --header "$FZF_HEADER" \
    --query "${QUERY_ARGS[*]:-}" \
    < "$PIPE_FIFO" \
    > "$TARGET_FILE"
FZF_EXIT=$?
set -e

# --- 9. 执行安装 (引入 KISS 留痕逻辑) ---
if [[ $FZF_EXIT -eq 0 ]] && [[ -s "$TARGET_FILE" ]]; then
    mapfile -t SELECTED_LINES < "$TARGET_FILE"
    PACKAGES=()
    
    for line in "${SELECTED_LINES[@]}"; do
        clean="${line%% ✔ *}"
        app_id=$(echo "$clean" | awk '{print $NF}')
        [[ -n "$app_id" ]] && PACKAGES+=("$app_id")
    done
    
    if [[ ${#PACKAGES[@]} -gt 0 ]]; then
        # 1. 组合最终命令
        FINAL_CMD="flatpak install ${PACKAGES[*]}"

        echo -e "\n\033[32m${MSG[INSTALLING]}\033[0m"
        echo "${PACKAGES[*]}"
        echo "----------------------------------------"
        
        # 2. 安装前静默打印
        echo -e "\033[90m${MSG[EXEC]}$FINAL_CMD\033[0m\n"

        # 3. 真正执行安装（【关键修复】：在此恢复语言环境，让安装提示显示中文）
        LC_ALL="$ORIGINAL_LANG" flatpak install "${PACKAGES[@]}"

        # 4. 安装结束后高亮留痕
        echo "----------------------------------------"
        echo -e "\033[36m${MSG[HINT]}\033[0m"
        echo -e "\033[1;33m$FINAL_CMD\033[0m\n"
    fi
fi
